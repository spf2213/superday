# ─── Client (Vite) ──────────────────────────────────────────────
# The anon key is safe to expose as long as Row-Level Security is
# enabled on every table. The URL is also non-secret.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Server (Vercel functions only) ─────────────────────────────
# Never prefix with VITE_ — these must NOT ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs. Create three Products in the Stripe dashboard:
#   • "Superday Weekly"   — recurring, $5/week
#   • "Superday Monthly"  — recurring, $15/month
#   • "Superday Lifetime" — one-time, $79
# Copy each price's `price_…` ID below.
STRIPE_PRICE_WEEKLY=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_LIFETIME=price_...

# Optional: fallback origin for Stripe redirect URLs when the request
# Origin header is missing (e.g. server-side webhook contexts). On Vercel,
# this is usually unnecessary because VERCEL_URL is auto-set.
PUBLIC_BASE_URL=https://app.superday.example

# Optional: extra origins allowed to call /api/checkout, /api/portal, and
# /api/claude. Comma-separated. PUBLIC_BASE_URL and VERCEL_URL are always
# allowed in addition to anything you list here. Use this when serving the
# SPA from a custom domain that isn't PUBLIC_BASE_URL.
#   ALLOWED_ORIGINS=https://superday.com,https://www.superday.com
